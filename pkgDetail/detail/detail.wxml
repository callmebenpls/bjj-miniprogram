<!-- Reusable renderer for data-driven content blocks (top/mid/bottom slots) -->
<template name="contentBlocks">
  <view wx:for="{{blocks}}" wx:for-item="blk" wx:key="index" class="content-block">
    <view wx:if="{{blk.type === 'heading'}}" class="{{blk.level === 1 ? 'block-heading-1' : 'block-heading-2'}}" style="border-bottom-color:{{config.detail.accent || '#c0392b'}}">{{blk.text}}</view>
    <view wx:elif="{{blk.type === 'text'}}" class="block-text">{{blk.text}}</view>
    <view wx:elif="{{blk.type === 'image'}}" class="block-image-wrap">
      <image src="{{blk.src}}" mode="widthFix" class="block-image" />
      <view wx:if="{{blk.caption}}" class="block-caption">{{blk.caption}}</view>
    </view>
    <view wx:elif="{{blk.type === 'list'}}" class="block-list">
      <view wx:for="{{blk.items}}" wx:for-item="li" wx:key="index" class="block-list-item">
        <text class="block-list-bullet" style="color:{{config.detail.accent || '#c0392b'}}">{{blk.ordered ? (index+1)+'.' : '•'}}</text>
        <text class="block-list-text">{{li}}</text>
      </view>
    </view>
    <view wx:elif="{{blk.type === 'quote'}}" class="block-quote" style="border-left-color:{{config.detail.accent || '#c0392b'}}">
      <view class="block-quote-text">{{blk.text}}</view>
      <view wx:if="{{blk.author}}" class="block-quote-author">— {{blk.author}}</view>
    </view>
    <view wx:elif="{{blk.type === 'divider'}}" class="divider-wrap">
      <view class="divider-dash"></view>
      <view class="divider-star">✦ ✦ ✦</view>
    </view>
    <view wx:elif="{{blk.type === 'button'}}" class="block-button-wrap">
      <button class="block-button" style="background:{{config.detail.shareColor || '#c0392b'}}" data-action="{{blk.action}}" data-value="{{blk.value}}" bindtap="onBlockButton" hover-class="big-share-hover">{{blk.text}}</button>
    </view>
    <rich-text wx:elif="{{blk.type === 'rich'}}" nodes="{{blk.html}}" class="block-rich"></rich-text>
  </view>
</template>

<view class="top-bar">
  <view class="back-bar" style="padding-top:{{navTop}}px" bindtap="goBack">← 返回</view>
</view>

<!-- Top accent bar — dynamic color -->
<view class="top-accent" style="background:{{config.detail.accent || '#c0392b'}}"></view>

<!-- ===== LOADING ===== -->
<view wx:if="{{loading}}" class="loading-state">
  <view class="loading-dot"></view>
  <view class="loading-text">加载中...</view>
</view>

<block wx:elif="{{course}}">

<!-- ===== HEADER ===== -->
<view class="article-header" style="border-bottom-color:{{config.detail.accent || '#c0392b'}}">
  <view class="header-title">{{course.titleCn || course.title}}</view>
  <view class="header-subtitle">{{course.title}}</view>
  <view class="header-instructor">
    <text class="header-label-accent" style="color:{{config.detail.accent || '#c0392b'}}">讲师</text> {{course.coachText}}
    <view wx:if="{{course.badgeIcons.length > 0}}" style="margin-top:6px">
      <text wx:for="{{course.badgeIcons}}" wx:for-item="icon" wx:key="*this" style="margin-right:6px;font-size:16px">{{icon}}</text>
    </view>
  </view>
</view>

<!-- ===== COVER IMAGE ===== -->
<view wx:if="{{course.image && config.detail.showCover !== false}}" class="cover-wrap">
  <image src="{{course.image}}" mode="widthFix" class="cover-img" />
</view>

<!-- ===== CONTENT BLOCKS (position: "top") ===== -->
<template is="contentBlocks" data="{{blocks: course.blocksTop, config}}"/>

<!-- ===== DESCRIPTION ===== -->
<view wx:if="{{config.detail.showDescription !== false}}" class="section-wrap">
  <view class="section-title-bar" style="border-bottom-color:{{config.detail.accent || '#c0392b'}}">课程介绍</view>
  <view class="desc-text">{{course.desc}}</view>
</view>

<!-- ===== CONTENT BLOCKS (default position) ===== -->
<template is="contentBlocks" data="{{blocks: course.blocksMid, config}}"/>

<!-- ===== DIVIDER ===== -->
<view class="divider-wrap">
  <view class="divider-dash"></view>
  <view class="divider-star">✦ ✦ ✦</view>
</view>

<!-- ===== BIG SHARE BUTTON ===== -->
<view class="big-share-wrap">
  <button class="big-share-btn" style="background:{{config.detail.shareColor || '#c0392b'}}" open-type="share" hover-class="big-share-hover">{{config.detail.shareText || '分享给朋友'}}</button>
</view>

<!-- ===== CHAPTERS ===== -->
<view class="section-wrap">
  <view class="section-title-bar" style="border-bottom-color:{{config.detail.accent || '#c0392b'}}">章节列表</view>

  <view wx:if="{{course.parts.length === 0}}" class="empty-chapters">暂无章节信息</view>

  <view wx:for="{{course.parts}}" wx:for-item="part" wx:key="index" class="part-card">
    <view class="part-header" style="background:{{config.detail.headerBg || '#1a1a2e'}}">
      <text class="part-badge" style="background:{{config.detail.accent || '#c0392b'}}">{{part.en}}</text>
      <text wx:if="{{part.cn}}" class="part-title-cn">· {{part.cn}}</text>
    </view>
    <view class="ch-th-row">
      <text class="ch-th" style="width:46%;">节目标题</text>
      <text class="ch-th" style="width:38%;">中文</text>
      <text class="ch-th" style="width:16%;">时长</text>
    </view>
    <view wx:for="{{part.ch}}" wx:for-item="ch" wx:key="index" class="ch-row">
      <text class="ch-td" style="width:46%;font-size:{{config.detail.chapterFontSize || 13}}px">{{ch[0]}}</text>
      <text class="ch-td-cn" style="width:38%;font-size:{{config.detail.chapterFontSize || 13}}px">{{ch[1]}}</text>
      <text class="ch-td-cn" style="width:16%;font-size:{{config.detail.chapterFontSize || 13}}px">{{ch[2]}}</text>
    </view>
  </view>
  <view wx:if="{{course.parts.length > 0}}" class="part-summary">共 {{course.parts.length}} 部分</view>
</view>

<!-- ===== CONTENT BLOCKS (position: "bottom") ===== -->
<template is="contentBlocks" data="{{blocks: course.blocksBottom, config}}"/>

<!-- ===== FOOTER ===== -->
<view class="footer-line">{{config.detail.footerText || '2026'}}</view>

<view class="bottom-accent" style="background:{{config.detail.accent || '#c0392b'}}"></view>

</block>
