.status-bar {
  padding: 44px 20px 4px;
  padding-top: calc(env(safe-area-inset-top) + 8px);
  font-size: 22px;
  font-weight: 600;
  color: #111;
  letter-spacing: -0.3px;
}
.loading-state {
  padding: 120px 20px;
  text-align: center;
}
.loading-dot {
  width: 28px;
  height: 28px;
  margin: 0 auto 14px;
  border: 3px solid #eee;
  border-top-color: #c0392b;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  font-size: 13px;
  color: #bbb;
}
.badge-icon {
  margin-right: 4px;
  font-size: 14px;
}
.page {
  height: 100vh;
  padding-bottom: 20px;
}
.search-bar {
  padding: 10px 20px 14px;
}
.search-input {
  background: #f5f5f5;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 14px;
  color: #111;
  width: 100%;
  border: none;
  outline: none;
}
.section-label {
  font-size: 13px;
  font-weight: 500;
  color: #888;
  padding: 0 20px 10px;
  letter-spacing: 0.3px;
}
.chip-scroll {
  padding: 0 20px 14px;
  white-space: nowrap;
}
.chip-row {
  display: inline-flex;
  gap: 8px;
}
.chip {
  display: inline-block;
  padding: 6px 16px;
  border-radius: 8px;
  font-size: 13px;
  background: #f5f5f5;
  color: #888;
  transition: all 0.2s;
}
.chip.active {
  background: #111;
  color: #fff;
  font-weight: 500;
}
.coach-scroll {
  padding: 0 20px 18px;
  white-space: nowrap;
}
.coach-item {
  display: inline-block;
  text-align: center;
  margin-right: 16px;
}
.coach-avatar {
  width: 52px;
  height: 52px;
  border-radius: 26px;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 500;
  color: #888;
  margin: 0 auto 6px;
  transition: all 0.2s;
  overflow: hidden;
}
.coach-avatar-img {
  width: 52px;
  height: 52px;
  border-radius: 26px;
  display: block;
}
.coach-avatar.all-icon {
  font-size: 18px;
}
.coach-item.active .coach-avatar {
  background: #111;
  color: #fff;
  box-shadow: 0 0 0 2px #111;
}
.coach-name-sm {
  font-size: 11px;
  color: #888;
  text-align: center;
}
.coach-item.active .coach-name-sm {
  color: #111;
  font-weight: 500;
}
.coach-count {
  font-size: 10px;
  color: #bbb;
  text-align: center;
}
.course-card {
  display: flex;
  gap: 14px;
  padding: 14px 20px;
  border-bottom: 1rpx solid #f5f5f5;
}
.course-thumb {
  width: 64px;
  height: 64px;
  border-radius: 10px;
  flex-shrink: 0;
}
.course-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.course-title {
  font-size: 14px;
  font-weight: 500;
  color: #111;
  margin-bottom: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.course-instructor {
  font-size: 12px;
  color: #888;
}
.course-meta {
  font-size: 11px;
  color: #bbb;
  margin-top: 3px;
}
.empty-state {
  padding: 40px 20px;
  text-align: center;
  color: #ccc;
  font-size: 14px;
}
